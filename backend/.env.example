# Supabase - Transaction pooler (porta 6543) — usado pelo Prisma Client em runtime
DATABASE_URL="postgresql://postgres.[SEU-PROJECT-REF]:[SUA-SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase - Conexão direta (porta 5432) — usado pelo Prisma Migrate
DIRECT_URL="postgresql://postgres:[SUA-SENHA]@db.[SEU-PROJECT-REF].supabase.co:5432/postgres"

JWT_SECRET="sua-chave-secreta-aqui-mude-em-producao"
JWT_EXPIRATION="7d"

# API-Football (api-football.com direto — plano free: 100 req/dia)
# Pegue sua chave em: https://dashboard.api-football.com → Profile
FOOTBALL_API_KEY=""

# Se preferir usar via RapidAPI, descomente e preencha:
# RAPIDAPI_KEY=""

FRONTEND_URL="http://localhost:3000"
PORT=3001
